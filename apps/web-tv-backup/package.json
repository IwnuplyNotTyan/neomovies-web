    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vite-plugin-solid": "^2.11.12"
  },
  "dependencies": {
    "@neomovies/api-client": "workspace:*",
    "@noriginmedia/norigin-spatial-navigation": "^3.1.0",
    "@noriginmedia/norigin-spatial-navigation-core": "^3.1.0",
    "axios": "^1.16.1",
